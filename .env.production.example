# Primer produkcijskih nastavitev za Linux server (docker compose).
# Kopiraj v `.env` poleg docker-compose.yml in izpolni vrednosti.

# --- PostgreSQL (uporablja jih storitev "db" in "app") ---
POSTGRES_USER=demokrati
POSTGRES_PASSWORD=spremeni-to-geslo
POSTGRES_DB=demokrati

# --- Payload ---
# Generiraj naključen niz, npr.:  openssl rand -base64 32
PAYLOAD_SECRET=spremeni-to-v-dolg-nakljucen-niz

# Javni URL strani (tvoja domena)
NEXT_PUBLIC_SERVER_URL=https://demokratiradovljica.com

# Google Search Console potrditev (neobvezno – ali prek DNS v Cloudflaru)
GOOGLE_SITE_VERIFICATION=

# --- Cloudflare Tunnel ---
# Token iz Cloudflare Zero Trust → Networks → Tunnels → (tunel) → Docker ukaz (--token ...)
TUNNEL_TOKEN=

# --- E-pošta (Resend prek SMTP) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxx
# Po potrditvi domene v Resendu uporabi naslov na svoji domeni:
SMTP_FROM=info@demokratiradovljica.com
ADMIN_NOTIFY_EMAIL=info@demokratiradovljica.com

# --- AI modul (Anthropic / Claude) ---
ANTHROPIC_API_KEY=
# Model za AI pomoč: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
AI_MODEL=claude-opus-4-8
